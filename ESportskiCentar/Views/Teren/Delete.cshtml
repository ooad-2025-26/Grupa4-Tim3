@model ESportskiCentar.Models.Teren

@{
    ViewData["Title"] = "Obriši";
}

<section class="hero">
    <div class="hero-content">
        <h1>Obriši teren</h1>
        <p>Potvrdite brisanje terena.</p>
    </div>
</section>

<div class="page-card">

    <h1>Da li ste sigurni?</h1>

    <p>
        <strong>Naziv:</strong>
        @Model.naziv
    </p>

    <p>
        <strong>Sport:</strong>
        @Model.sport
    </p>

    <form asp-action="Delete">

        <input type="hidden" asp-for="id" />

        <div class="text-center mt-4">

            <button type="submit" class="btn btn-danger-custom">
                Obriši
            </button>

            <a asp-action="Index"
                   class="btn btn-secondary-custom ms-2">
                Odustani
            </a>

        </div>

    </form>

</div>