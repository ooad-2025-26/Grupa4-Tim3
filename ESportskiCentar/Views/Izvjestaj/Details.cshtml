@model ESportskiCentar.Models.Izvjestaj

@{
    ViewData["Title"] = "Detalji izvještaja";
}

<section class="hero">
    <div class="hero-content">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1>Izvještaj</h1>
                <p>
                    Pregled generisanog izvještaja.
                </p>
            </div>
            <div class="col-md-6 text-center">
                <div>
                    <img src="~/images/logo.png" alt="ESportskiCentar Logo" width="300" />
                </div>
            </div>
        </div>
    </div>
</section>

<table class="table table-custom">
    <tbody>
        <tr>
            <th>Korisnik</th>
            <td>@Model.Korisnik?.Email</td>
        </tr>
        <tr>
            <th>Od datuma</th>
            <td>@Model.datumOd.ToString("dd.MM.yyyy")</td>
        </tr>
        <tr>
            <th>Do datuma</th>
            <td>@Model.datumDo.ToString("dd.MM.yyyy")</td>
        </tr>
        <tr>
            <th>Datum generisanja</th>
            <td>@Model.datumGenerisanja.ToString("dd.MM.yyyy HH:mm")</td>
        </tr>
        <tr>
            <th>Ukupno rezervacija</th>
            <td>@Model.ukupnoRezervacija</td>
        </tr>
        <tr>
            <th>Ukupna zarada</th>
            <td>@Model.ukupnaZarada KM</td>
        </tr>
    </tbody>
</table>
<div class="text-center mt-4 mb-5">

    <a asp-action="Index"
           class="btn btn-secondary-custom px-4">
        Nazad
    </a>

</div>