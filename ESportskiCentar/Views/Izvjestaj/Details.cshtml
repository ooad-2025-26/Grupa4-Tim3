@model ESportskiCentar.Models.Izvjestaj

@{
    ViewData["Title"] = "Detalji izvještaja";
}

<section class="hero">
    <div class="hero-content">
        <h1>Izvještaj</h1>
        <p>Pregled generisanog izvještaja.</p>
    </div>
</section>

<table class="table table-custom">
    <tbody>
        <tr>
            <th>Korisnik</th>
            <td>@Model.Korisnik?.Email</td>
        </tr>
        <tr>
            <th>Od datuma</th>
            <td>@Model.datumOd.ToString("dd.MM.yyyy")</td>
        </tr>
        <tr>
            <th>Do datuma</th>
            <td>@Model.datumDo.ToString("dd.MM.yyyy")</td>
        </tr>
        <tr>
            <th>Datum generisanja</th>
            <td>@Model.datumGenerisanja.ToString("dd.MM.yyyy HH:mm")</td>
        </tr>
        <tr>
            <th>Ukupno rezervacija</th>
            <td>@Model.ukupnoRezervacija</td>
        </tr>
        <tr>
            <th>Ukupna zarada</th>
            <td>@Model.ukupnaZarada KM</td>
        </tr>
    </tbody>
</table>