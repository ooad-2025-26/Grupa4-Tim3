@model ESportskiCentar.Models.Izvjestaj

@{
    ViewData["Title"] = "Izvještaji";
}

<section class="hero">
    <div class="hero-content">
        <h1>Izvještaji</h1>
        <p>Odaberite vremenski period za generisanje izvještaja.</p>
    </div>
</section>

<div class="form-panel">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="row align-items-end">
            <div class="col-md-5">
                <label asp-for="datumOd">Od datuma:</label>
                <input asp-for="datumOd" type="date" class="form-control" />
            </div>

            <div class="col-md-5">
                <label asp-for="datumDo">Do datuma:</label>
                <input asp-for="datumDo" type="date" class="form-control" />
            </div>

            <div class="col-md-2">
                <button type="submit" class="btn btn-main w-100">Generiši</button>
            </div>
        </div>
    </form>
</div>