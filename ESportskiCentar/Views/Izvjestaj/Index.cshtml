@model IEnumerable<ESportskiCentar.Models.Izvjestaj>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.datumGenerisanja)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.datumOd)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.datumDo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Korisnik)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.datumGenerisanja)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.datumOd)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.datumDo)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Korisnik.id)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
