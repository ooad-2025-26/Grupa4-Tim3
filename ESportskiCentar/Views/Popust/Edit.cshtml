@model ESportskiCentar.Models.Popust

@{
    ViewData["Title"] = "Uredi popust";
}

<section class="hero">
    <div class="hero-content">
        <h1>Uredi popust</h1>
        <p>Izmijenite pravilo za automatsku dodjelu popusta.</p>
    </div>
</section>

<div class="page-card">
    <h1>Uredi popust</h1>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="id" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="potrebanBrojRezervacija" class="form-label">Broj rezervacija</label>
            <input asp-for="potrebanBrojRezervacija" class="form-control" />
            <span asp-validation-for="potrebanBrojRezervacija" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="procenat" class="form-label">Popust (%)</label>
            <input asp-for="procenat" class="form-control" />
            <span asp-validation-for="procenat" class="text-danger"></span>
        </div>

        <div class="text-center">
            <button type="submit" class="btn btn-main">Sačuvaj</button>
            <a asp-action="Index" class="btn btn-secondary-custom ms-2">Nazad</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}