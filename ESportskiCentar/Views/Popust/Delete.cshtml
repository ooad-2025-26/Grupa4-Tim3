@model ESportskiCentar.Models.Popust

@{
    ViewData["Title"] = "Obriši popust";
}

<section class="hero">
    <div class="hero-content">
        <h1>Obriši popust</h1>
        <p>Potvrdite brisanje pravila za popust.</p>
    </div>
</section>

<div class="page-card">
    <h1>Da li ste sigurni?</h1>

    <p>
        <strong>Broj rezervacija:</strong>
        @Model.potrebanBrojRezervacija
    </p>

    <p>
        <strong>Popust:</strong>
        @Model.procenat %
    </p>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="id" />

        <div class="text-center mt-4">
            <button type="submit" class="btn btn-main">
                Obriši
            </button>

            <a asp-action="Index" class="btn btn-secondary ms-2">
                Odustani
            </a>
        </div>
    </form>
</div>