@model IEnumerable<ESportskiCentar.Models.Popust>

@{
    ViewData["Title"] = "Popusti";
}

<section class="hero">
    <div class="hero-content">
        <h1>Popusti</h1>
        <p>Definisanje pravila za automatsku dodjelu popusta.</p>
    </div>
</section>

<div class="text-center mt-4">
    <a asp-action="Create" class="btn btn-main">Novi popust</a>
</div>

<table class="table table-custom">
    <thead>
        <tr>
            <th>Broj rezervacija</th>
            <th>Popust (%)</th>
            <th>Akcije</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.potrebanBrojRezervacija</td>
                <td>@item.procenat</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.id">Uredi</a> |
                    <a asp-action="Delete" asp-route-id="@item.id">Obriši</a>
                </td>
            </tr>
        }
    </tbody>
</table>