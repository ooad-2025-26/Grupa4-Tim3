@model IEnumerable<ESportskiCentar.Models.Rezervacija>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.vrijemeRezervacije)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.primjenjenPopust)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.konacnaCijena)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Termin)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Korisnik)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.status)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.vrijemeRezervacije)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.primjenjenPopust)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.konacnaCijena)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Termin.id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Korisnik.Id)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
