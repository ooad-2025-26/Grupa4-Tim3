@model ESportskiCentar.Models.Rezervacija

@{
    ViewData["Title"] = "Otkaži rezervaciju";
}

<section class="hero">
    <div class="hero-content">
        <h1>Otkaži<br />rezervaciju</h1>
        <p>Provjeri detalje termina prije otkazivanja.</p>
    </div>
</section>

<div class="page-card">
    <h1>Detalji rezervacije</h1>

    <p><strong>Sport:</strong> @Model.Termin?.Teren?.sport</p>
    <p><strong>Teren:</strong> @Model.Termin?.Teren?.naziv</p>
    <p><strong>Vrijeme:</strong> @Model.Termin?.datum.ToString("dd.MM.yyyy HH:mm")</p>
    <p><strong>Cijena:</strong> @Model.konacnaCijena KM</p>

    <p class="text-success fw-bold">
        Rezervaciju je moguće otkazati najkasnije 24 sata prije termina.
    </p>

    <form asp-action="Delete">
        <input type="hidden" asp-for="id" />
        <div class="text-center">
            <button type="submit" class="btn btn-main">Otkaži</button>
            <a asp-controller="Rezervacija"
                   asp-action="Index"
                   class="btn btn-secondary ms-2">
                Nazad
            </a>
        </div>
    </form>
</div>